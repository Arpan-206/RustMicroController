KMD
00000000:             ;         ;       ----------------------------------------------------------
00000000:             ;         ;       RISC-V Stopwatch OS Kernel
00000000:             ;         ;       A. Pandey
00000000:             ;         ;       Version 1.0
00000000:             ;         ;       17th March 2026
00000000:             ;         ;       ----------------------------------------------------------
00000000:             ; 
00000000:             ;         ORG     0
00000000:             ; 
00000000:             ;         INCLUDE os_consts.s
00000000:             ;         ;                ----------------------------------------------------------
00000000:             ;         ;                OS Constants, Hardware Addresses and Syscall Definitions
00000000:             ;         ;                A. Pandey
00000000:             ;         ;                Version 1.0
00000000:             ;         ;                17th March 2026
00000000:             ;         ;                ----------------------------------------------------------
00000000:             ; 
00000000:             ; 
00000000:             ;         ;                Memory mapped IO base addresses
00000000:             ;         HALT_PORT        EQU 0x00010700
00000000:             ;         LCD_BASE         EQU 0x00010100
00000000:             ; 
00000000:             ; 
00000000:             ;         ;                MSTATUS bits 12 and 11 form the MPP field
00000000:             ;         MPP_MASK         EQU 0x00001800
00000000:             ; 
00000000:             ; 
00000000:             ;         ;                MCAUSE code for ECALL from user mode
00000000:             ;         CAUSE_ECALL_U    EQU 8
00000000:             ; 
00000000:             ; 
00000000:             ;         ;                OS stack size in bytes
00000000:             ;         OS_STACK_SIZE    EQU 256
00000000:             ; 
00000000:             ; 
00000000:             ;         ;                Syscall numbers
00000000:             ;         SYS_EXIT         EQU 0
00000000:             ;         SYS_LCD_CHAR     EQU 1
00000000:             ;         SYS_LCD_CLEAR    EQU 2
00000000:             ;         HALT_PORT        EQU 0x00010700
00000000:             ;         LCD_BASE         EQU 0x00010100
00000000:             ; 
00000000:             ;         ;                MSTATUS bits 12 and 11 form the MPP field
00000000:             ;         MPP_MASK         EQU 0x00001800
00000000:             ; 
00000000:             ;         ;                MCAUSE code for ECALL from user mode
00000000:             ;         CAUSE_ECALL_U    EQU 8
00000000:             ; 
00000000:             ;         ;                OS stack size in bytes
00000000:             ;         OS_STACK_SIZE    EQU 256
00000000:             ; 
00000000:             ;         ;                Syscall numbers
00000000:             ;         SYS_EXIT         EQU 0
00000000:             ;         SYS_LCD_CHAR     EQU 1
00000000:             ;         SYS_LCD_CLEAR    EQU 2
00000000:             ;         SYS_BTN_READ     EQU 3
00000000:             ;         SYS_TIMER_INIT   EQU 4
00000000:             ;         SYS_TIMER_POLL   EQU 5
00000000:             ;         SYS_TIMER_ACK    EQU 6
00000000:             ;         SYS_MAX          EQU 7
00000000:             ; 
00000000:             ;         ;                LCD hardware constants
00000000:             ;         r_input          EQU 0b1001
00000000:             ;         r_output         EQU 0b1010
00000000:             ;         lcd_e_bit        EQU 0x04
00000000:             ;         lcd_e_clear      EQU 0xfb
00000000:             ;         lcd_busy_flag    EQU 0x80
00000000:             ;         lcd_ctrl_cmd     EQU 0b1000
00000000:             ;         delay_short      EQU 20
00000000:             ;         delay_poll       EQU 48
00000000:             ; 
00000000:             ;         ;                LCD commands
00000000:             ;         lcd_cmd_clear    EQU 0x01
00000000:             ;         lcd_cmd_home     EQU 0x02
00000000:             ;         lcd_cmd_line1    EQU 0x80
00000000:             ;         lcd_cmd_line2    EQU 0xc0
00000000:             ; 
00000000:             ;         ;                ASCII control codes
00000000:             ;         ascii_lf         EQU 0x0a
00000000:             ;         ascii_cr         EQU 0x0d
00000000:             ;         ascii_ff         EQU 0x0c
00000000:             ; 
00000000:             ;         ;                Button port
00000000:             ;         BTN_PORT         EQU 0x00010001
00000000:             ;         BTN_START        EQU 0x01
00000000:             ;         BTN_PAUSE        EQU 0x02
00000000:             ;         BTN_RESET        EQU 0x04
00000000:             ; 
00000000:             ;         ;                Timer peripheral offsets from TIMER_BASE
00000000:             ;         TIMER_BASE       EQU 0x00010200
00000000:             ;         TIMER_LIMIT      EQU 0x04
00000000:             ;         TIMER_CTRL       EQU 0x0C
00000000:             ;         TIMER_CLR        EQU 0x10
00000000:             ;         TIMER_SET        EQU 0x14
00000000:             ; 
00000000:             ;         ;                Timer control bits
00000000:             ;         TIMER_EN         EQU 0x01
00000000:             ;         TIMER_MOD        EQU 0x02
00000000:             ;         TIMER_CLR_TERM   EQU 0x10
00000000:             ; 
00000000:             ;         ;                1 second modulus at 1MHz limit = modulus - 1
00000000:             ;         TIMER_1S         EQU 999999
00000000:             ;         TIMER_1MS        EQU 999
00000000:             ; 
00000000:             ;         bcd_sec_max      EQU 0x60 ; BCD 60 seconds per minute
00000000:             ;         bcd_min_max      EQU 0x60 ; BCD 60 minutes per hour
00000000:             ;         bcd_hr_max       EQU 0x24 ; BCD 24 hours per day
00000000:             ;         bcd_digit_max    EQU 10 ; first invalid single BCD digit
00000000:             ;         bcd_carry_adjust EQU 6 ; correction to skip hex A-F gap
00000000:             ;         USER_STACK_SIZE  EQU 512 ; user stack depth in bytes
00000000:             ; 
00000000:             ;         SYS_BTN_READ     EQU 3
00000000:             ;         SYS_TIMER_INIT   EQU 4
00000000:             ;         SYS_TIMER_POLL   EQU 5
00000000:             ;         SYS_TIMER_ACK    EQU 6
00000000:             ;         SYS_MAX          EQU 7
00000000:             ; 
00000000:             ; 
00000000:             ;         ;                LCD hardware constants
00000000:             ;         r_input          EQU 0b1001 ; control pattern for read mode
00000000:             ;         r_output         EQU 0b1010 ; control pattern for write mode
00000000:             ;         lcd_e_bit        EQU 0x04 ; enable bit mask
00000000:             ;         lcd_e_clear      EQU 0xfb ; enable bit clear mask
00000000:             ;         lcd_busy_flag    EQU 0x80 ; busy flag in bit 7 of read data
00000000:             ;         lcd_ctrl_cmd     EQU 0b1000 ; backlight on, RS low for command
00000000:             ;         delay_short      EQU 20 ; short delay loop count for enable pulse
00000000:             ;         delay_poll       EQU 48 ; longer delay between poll reads
00000000:             ; 
00000000:             ; 
00000000:             ;         ;                LCD commands
00000000:             ;         lcd_cmd_clear    EQU 0x01 ; clear display and reset DDRAM address
00000000:             ;         lcd_cmd_home     EQU 0x02 ; return cursor to home position
00000000:             ;         lcd_cmd_line1    EQU 0x80 ; DDRAM address for start of line 1
00000000:             ;         lcd_cmd_line2    EQU 0xc0 ; DDRAM address for start of line 2
00000000:             ; 
00000000:             ; 
00000000:             ;         ;                ASCII control codes
00000000:             ;         ascii_lf         EQU 0x0a ; line feed, used to move to line 2
00000000:             ;         ascii_cr         EQU 0x0d ; carriage return, used to move to line 1
00000000:             ;         ascii_ff         EQU 0x0c ; form feed, used to clear display
00000000:             ; 
00000000:             ; 
00000000:             ;         ;                Button port address and bit masks
00000000:             ;         BTN_PORT         EQU 0x00010001
00000000:             ;         BTN_START        EQU 0x01 ; bit 0 starts the stopwatch
00000000:             ;         BTN_PAUSE        EQU 0x02 ; bit 1 pauses the stopwatch
00000000:             ;         BTN_RESET        EQU 0x04 ; bit 2 resets the stopwatch
00000000:             ; 
00000000:             ; 
00000000:             ;         ;                Timer peripheral base and register offsets from TIMER_BASE
00000000:             ;         TIMER_BASE       EQU 0x00010200
00000000:             ;         TIMER_LIMIT      EQU 0x04 ; modulus register offset
00000000:             ;         TIMER_CTRL       EQU 0x0C ; control and status register offset
00000000:             ;         TIMER_CLR        EQU 0x10 ; control clear register offset
00000000:             ;         TIMER_SET        EQU 0x14 ; control set register offset
00000000:             ; 
00000000:             ; 
00000000:             ;         ;                Timer control bits
00000000:             ;         TIMER_EN         EQU 0x01 ; enable bit starts the counter
00000000:             ;         TIMER_MOD        EQU 0x02 ; modulus mode wraps at TIMER_LIMIT
00000000:             ;         TIMER_CLR_TERM   EQU 0x10 ; writing this clears terminal count flag
00000000:             ; 
00000000:             ; 
00000000:             ;         ;                Timer modulus values, limit register takes modulus minus 1
00000000:             ;         TIMER_1S         EQU 999999 ; 1 second at 1MHz tick rate
00000000:             ;         TIMER_1MS        EQU 999 ; 1 millisecond at 1MHz tick rate
00000000:             ; 
00000000:             ; 
00000000:             ;         ;                BCD arithmetic constants
00000000:             ;         bcd_sec_max      EQU 0x60 ; BCD 60 is the rollover point for seconds
00000000:             ;         bcd_min_max      EQU 0x60 ; BCD 60 is the rollover point for minutes
00000000:             ;         bcd_hr_max       EQU 0x24 ; BCD 24 is the rollover point for hours
00000000:             ;         bcd_digit_max    EQU 10 ; first value that needs carry correction
00000000:             ;         bcd_carry_adjust EQU 6 ; added to skip the hex A through F gap
00000000:             ; 
00000000:             ; 
00000000:             ;         ;                User space constants
00000000:             ;         USER_STACK_SIZE  EQU 512 ; user stack depth in bytes
00000000:             ;         ascii_zero       EQU 48 ; ASCII value of digit zero
00000000:             ;         ascii_colon      EQU 58 ; ASCII value of separator character
00000000:             ; 
00000000:             ; 
00000000:             ; 
00000000:             ;         ;       ----------------------------------------------------------
00000000:             ;         ;       init
00000000:             ;         ;       Input none
00000000:             ;         ;       Saved nothing
00000000:             ;         ;       Clobbers t0
00000000:             ;         ;       Effect sets up OS stack, installs trap vector, clears LCD,
00000000:             ;         ;       drops to user mode and jumps to USER_CODE via mret
00000000:             ;         ;       ----------------------------------------------------------
00000000:             ; init:
00000000: 00000117    ;         la      sp, os_stack_top
00000004: 42010113    ; 
00000008: 34011073    ;         csrw    MSCRATCH, sp
0000000C:             ; 
0000000C: 00000297    ;         la      t0, trap_entry
00000010: 02C28293    ; 
00000014: 30529073    ;         csrw    MTVEC, t0
00000018:             ; 
00000018: 1C8000EF    ;         call    lcd_clear
0000001C:             ; 
0000001C: 000022B7    ;         li      t0, MPP_MASK
00000020: 80028293    ; 
00000024: 3002B073    ;         csrc    MSTATUS, t0
00000028: 00040297    ;         la      t0, USER_CODE
0000002C: 1D828293    ; 
00000030: 34129073    ;         csrw    MEPC, t0
00000034: 30200073    ;         mret
00000038:             ; 
00000038:             ; 
00000038:             ;         ;       ----------------------------------------------------------
00000038:             ;         ;       trap_entry
00000038:             ;         ;       Input machine trap frame via CSRs
00000038:             ;         ;       Saved ra t0 a7 MEPC on OS stack
00000038:             ;         ;       Clobbers t0 t1
00000038:             ;         ;       Effect swaps to OS stack, saves minimal context, checks
00000038:             ;         ;       cause is ecall from user, dispatches via sys_table,
00000038:             ;         ;       falls through to trap_error on any unexpected cause
00000038:             ;         ;       ----------------------------------------------------------
00000038:             ; trap_entry:
00000038: 34011173    ;         csrrw   sp, MSCRATCH, sp
0000003C: FF010113    ;         subi    sp, sp, 16
00000040: 00112023    ;         sw      ra, 0[sp]
00000044: 00512223    ;         sw      t0, 4[sp]
00000048: 01112423    ;         sw      a7, 8[sp]
0000004C: 341022F3    ;         csrr    t0, MEPC
00000050: 00512623    ;         sw      t0, 12[sp]
00000054:             ; 
00000054: 342022F3    ;         csrr    t0, MCAUSE
00000058: 00800313    ;         li      t1, CAUSE_ECALL_U
0000005C: 04629063    ;         bne     t0, t1, trap_error
00000060:             ; 
00000060: 00700293    ;         li      t0, SYS_MAX
00000064: 0258FC63    ;         bgeu    a7, t0, trap_error
00000068:             ; 
00000068: 00000297    ;         la      t0, sys_table
0000006C: 01828293    ; 
00000070: 00289313    ;         slli    t1, a7, 2
00000074: 006282B3    ;         add     t0, t0, t1
00000078: 0002A283    ;         lw      t0, 0[t0]
0000007C: 00028067    ;         jr      t0
00000080:             ; 
00000080:             ; 
00000080:             ;         ;       ----------------------------------------------------------
00000080:             ;         ;       sys_table
00000080:             ;         ;       Effect word table of handler addresses indexed by a7
00000080:             ;         ;       must stay in same order as SYS_ constants in os_consts.s
00000080:             ;         ;       ----------------------------------------------------------
00000080:             ; sys_table:
00000080: 000000D8    ;         defw    sys_exit
00000084: 000000EC    ;         defw    sys_lcd_char
00000088: 00000104    ;         defw    sys_lcd_clear
0000008C: 0000011C    ;         defw    sys_btn_read
00000090: 00000124    ;         defw    sys_timer_init
00000094: 0000012C    ;         defw    sys_timer_poll
00000098: 00000134    ;         defw    sys_timer_ack
0000009C:             ; 
0000009C:             ; 
0000009C:             ;         ;       ----------------------------------------------------------
0000009C:             ;         ;       trap_error
0000009C:             ;         ;       Input none
0000009C:             ;         ;       Saved nothing
0000009C:             ;         ;       Clobbers t0 t1
0000009C:             ;         ;       Effect writes something to HALT_PORT and spins forever
0000009C:             ;         ;       ----------------------------------------------------------
0000009C:             ; trap_error:
0000009C: 00010337    ;         li      t1, HALT_PORT
000000A0: 70030313    ; 
000000A4: 010102B7    ;         li      t0, 0x01010101 ; Does not really matter what is being sent
000000A8: 10128293    ; 
000000AC: 00532023    ;         sw      t0, 0[t1]
000000B0: FEDFF06F    ;         j       trap_error ; Just in case the halt somehow did not work
000000B4:             ; 
000000B4:             ; 
000000B4:             ;         ;       ----------------------------------------------------------
000000B4:             ;         ;       trap_return
000000B4:             ;         ;       Input saved context on OS stack
000000B4:             ;         ;       Saved nothing
000000B4:             ;         ;       Clobbers t0
000000B4:             ;         ;       Effect increments saved MEPC past ecall, restores context,
000000B4:             ;         ;       swaps back to user stack and returns to user mode
000000B4:             ;         ;       ----------------------------------------------------------
000000B4:             ; trap_return:
000000B4: 00C12283    ;         lw      t0, 12[sp] ; reload saved MEPC
000000B8: 00428293    ;         addi    t0, t0, 4 ; advance past the ecall instruction
000000BC: 34129073    ;         csrw    MEPC, t0 ; write updated return address
000000C0: 00812883    ;         lw      a7, 8[sp] ; restore syscall register
000000C4: 00412283    ;         lw      t0, 4[sp] ; restore t0
000000C8: 00012083    ;         lw      ra, 0[sp] ; restore return address
000000CC: 01010113    ;         addi    sp, sp, 16 ; deallocate trap frame
000000D0: 34011173    ;         csrrw   sp, MSCRATCH, sp ; swap OS sp back, restore user sp
000000D4: 30200073    ;         mret    ; return to user mode
000000D8:             ; 
000000D8:             ; 
000000D8:             ;         ;       ----------------------------------------------------------
000000D8:             ;         ;       sys_exit
000000D8:             ;         ;       Input none
000000D8:             ;         ;       Saved nothing
000000D8:             ;         ;       Clobbers t0 t1
000000D8:             ;         ;       Effect writes 0 to HALT_PORT and spins, never returns
000000D8:             ;         ;       ----------------------------------------------------------
000000D8:             ; sys_exit:
000000D8:             ;         ;       This is unused as of now but could be useful sometime later and it exists since
                      ;  we may want different exit logic at some point
000000D8: 00010337    ;         li      t1, HALT_PORT ; load halt port address
000000DC: 70030313    ; 
000000E0: 00000293    ;         li      t0, 0 ; clean exit code
000000E4: 00532023    ;         sw      t0, 0[t1] ; halt the processor
000000E8: FF1FF06F    ;         j       sys_exit ; spin in case halt does not fire
000000EC:             ; 
000000EC:             ; 
000000EC:             ;         ;       ----------------------------------------------------------
000000EC:             ;         ;       sys_lcd_char
000000EC:             ;         ;       Input a0 = character byte to print
000000EC:             ;         ;       Saved ra on OS stack
000000EC:             ;         ;       Clobbers a1 a2 a3 t2 t3 t5
000000EC:             ;         ;       Effect calls lcd_print_char then returns to user via trap_return
000000EC:             ;         ;       ----------------------------------------------------------
000000EC:             ; sys_lcd_char:
000000EC: FFC10113    ;         subi    sp, sp, 4 ; allocate frame for ra
000000F0: 00112023    ;         sw      ra, 0[sp] ; save ra before nested call
000000F4: 048000EF    ;         call    lcd_print_char ; delegate to LCD driver
000000F8: 00012083    ;         lw      ra, 0[sp] ; restore ra
000000FC: 00410113    ;         addi    sp, sp, 4 ; deallocate frame
00000100: FB5FF06F    ;         j       trap_return ; return to user mode
00000104:             ; 
00000104:             ; 
00000104:             ;         ;       ----------------------------------------------------------
00000104:             ;         ;       sys_lcd_clear
00000104:             ;         ;       Input none
00000104:             ;         ;       Saved ra on OS stack
00000104:             ;         ;       Clobbers a0 a1 a2 a3 t2 t3
00000104:             ;         ;       Effect calls lcd_clear then returns to user via trap_return
00000104:             ;         ;       ----------------------------------------------------------
00000104:             ; sys_lcd_clear:
00000104: FFC10113    ;         subi    sp, sp, 4 ; allocate frame for ra
00000108: 00112023    ;         sw      ra, 0[sp] ; save ra before nested call
0000010C: 0D4000EF    ;         call    lcd_clear ; delegate to LCD driver
00000110: 00012083    ;         lw      ra, 0[sp] ; restore ra
00000114: 00410113    ;         addi    sp, sp, 4 ; deallocate frame
00000118: F9DFF06F    ;         j       trap_return ; return to user mode
0000011C:             ; 
0000011C:             ; 
0000011C:             ;         ;       ----------------------------------------------------------
0000011C:             ;         ;       sys_btn_read
0000011C:             ;         ;       Input none
0000011C:             ;         ;       Saved nothing
0000011C:             ;         ;       Clobbers t0
0000011C:             ;         ;       Effect calls btn_read, result in a0, returns via trap_return
0000011C:             ;         ;       ----------------------------------------------------------
0000011C:             ; sys_btn_read:
0000011C: 188000EF    ;         call    btn_read ; read button port into a0
00000120: F95FF06F    ;         j       trap_return ; return to user mode
00000124:             ; 
00000124:             ; 
00000124:             ;         ;       ----------------------------------------------------------
00000124:             ;         ;       sys_timer_init
00000124:             ;         ;       Input a0 = modulus minus 1 value
00000124:             ;         ;       Saved nothing
00000124:             ;         ;       Clobbers t0 t1
00000124:             ;         ;       Effect calls timer_init then returns to user via trap_return
00000124:             ;         ;       ----------------------------------------------------------
00000124:             ; sys_timer_init:
00000124: 190000EF    ;         call    timer_init ; configure and start timer
00000128: F8DFF06F    ;         j       trap_return ; return to user mode
0000012C:             ; 
0000012C:             ; 
0000012C:             ;         ;       ----------------------------------------------------------
0000012C:             ;         ;       sys_timer_poll
0000012C:             ;         ;       Input none
0000012C:             ;         ;       Saved nothing
0000012C:             ;         ;       Clobbers t0 t1
0000012C:             ;         ;       Effect calls timer_poll, result in a0, returns via trap_return
0000012C:             ;         ;       ----------------------------------------------------------
0000012C:             ; sys_timer_poll:
0000012C: 1A0000EF    ;         call    timer_poll ; check terminal count status
00000130: F85FF06F    ;         j       trap_return ; return to user mode
00000134:             ; 
00000134:             ; 
00000134:             ;         ;       ----------------------------------------------------------
00000134:             ;         ;       sys_timer_ack
00000134:             ;         ;       Input none
00000134:             ;         ;       Saved nothing
00000134:             ;         ;       Clobbers t0 t1
00000134:             ;         ;       Effect calls timer_ack to clear sticky terminal count bit,
00000134:             ;         ;       returns to user via trap_return
00000134:             ;         ;       ----------------------------------------------------------
00000134:             ; sys_timer_ack:
00000134: 1C8000EF    ;         call    timer_ack ; clear terminal count flag
00000138: F7DFF06F    ;         j       trap_return ; return to user mode
0000013C:             ; 
