0000013C:             ;         ;       ----------------------------------------------------------
0000013C:             ;         ;       lcd_print_char(a0)
0000013C:             ;         ;       Input  a0 = character byte to print
0000013C:             ;         ;       Saved  ra
0000013C:             ;         ;       Clobbers a1 a2 a3 t2 t3 t5
0000013C:             ;         ;       Effect routes ascii_lf ascii_cr ascii_ff to control
0000013C:             ;         ;              routines, all other bytes written to LCD data
0000013C:             ;         ;       ----------------------------------------------------------
0000013C:             ; lcd_print_char:
0000013C: FFC10113    ;         subi    sp, sp, 4
00000140: 00112023    ;         sw      ra, 0[sp]
00000144:             ; 
00000144: 00A00F13    ;         li      t5, ascii_lf
00000148: 03E50463    ;         beq     a0, t5, lpc_newline
0000014C: 00D00F13    ;         li      t5, ascii_cr
00000150: 03E50463    ;         beq     a0, t5, lpc_home
00000154: 00C00F13    ;         li      t5, ascii_ff
00000158: 03E50463    ;         beq     a0, t5, lpc_clear
0000015C:             ; 
0000015C: 00010637    ;         li      a2, LCD_BASE
00000160: 10060613    ; 
00000164: 00A00693    ;         li      a3, r_output
00000168: 0A8000EF    ;         call    lcd_send
0000016C: 0180006F    ;         j       lpc_done
00000170:             ; 
00000170:             ; lpc_newline:
00000170: 020000EF    ;         call    lcd_new_line
00000174: 0100006F    ;         j       lpc_done
00000178:             ; 
00000178:             ; lpc_home:
00000178: 040000EF    ;         call    lcd_home_line
0000017C: 0080006F    ;         j       lpc_done
00000180:             ; 
00000180:             ; lpc_clear:
00000180: 060000EF    ;         call    lcd_clear
00000184:             ; 
00000184:             ; lpc_done:
00000184: 00012083    ;         lw      ra, 0[sp]
00000188: 00410113    ;         addi    sp, sp, 4
0000018C: 00008067    ;         ret
00000190:             ; 
00000190:             ; 
00000190:             ;         ;       ----------------------------------------------------------
00000190:             ;         ;       lcd_new_line()
00000190:             ;         ;       Input  none
00000190:             ;         ;       Saved  ra
00000190:             ;         ;       Clobbers a0 a1 a2 a3 t2 t3
00000190:             ;         ;       Effect sends DDRAM set-address command for start of line 2
00000190:             ;         ;       ----------------------------------------------------------
00000190:             ; lcd_new_line:
00000190: FFC10113    ;         subi    sp, sp, 4
00000194: 00112023    ;         sw      ra, 0[sp]
00000198: 00010637    ;         li      a2, LCD_BASE
0000019C: 10060613    ; 
000001A0: 0C000513    ;         li      a0, lcd_cmd_line2
000001A4: 00800693    ;         li      a3, lcd_ctrl_cmd
000001A8: 068000EF    ;         call    lcd_send
000001AC: 00012083    ;         lw      ra, 0[sp]
000001B0: 00410113    ;         addi    sp, sp, 4
000001B4: 00008067    ;         ret
000001B8:             ; 
000001B8:             ; 
000001B8:             ;         ;       ----------------------------------------------------------
000001B8:             ;         ;       lcd_home_line()
000001B8:             ;         ;       Input  none
000001B8:             ;         ;       Saved  ra
000001B8:             ;         ;       Clobbers a0 a1 a2 a3 t2 t3
000001B8:             ;         ;       Effect sends DDRAM set-address command for start of line 1
000001B8:             ;         ;       ----------------------------------------------------------
000001B8:             ; lcd_home_line:
000001B8: FFC10113    ;         subi    sp, sp, 4
000001BC: 00112023    ;         sw      ra, 0[sp]
000001C0: 00010637    ;         li      a2, LCD_BASE
000001C4: 10060613    ; 
000001C8: 08000513    ;         li      a0, lcd_cmd_line1
000001CC: 00800693    ;         li      a3, lcd_ctrl_cmd
000001D0: 040000EF    ;         call    lcd_send
000001D4: 00012083    ;         lw      ra, 0[sp]
000001D8: 00410113    ;         addi    sp, sp, 4
000001DC: 00008067    ;         ret
000001E0:             ; 
000001E0:             ; 
000001E0:             ;         ;       ----------------------------------------------------------
000001E0:             ;         ;       lcd_clear()
000001E0:             ;         ;       Input  none
000001E0:             ;         ;       Saved  ra
000001E0:             ;         ;       Clobbers a0 a1 a2 a3 t2 t3
000001E0:             ;         ;       Effect sends clear-display then return-home commands
000001E0:             ;         ;       ----------------------------------------------------------
000001E0:             ; lcd_clear:
000001E0: FFC10113    ;         subi    sp, sp, 4
000001E4: 00112023    ;         sw      ra, 0[sp]
000001E8: 00010637    ;         li      a2, LCD_BASE
000001EC: 10060613    ; 
000001F0: 00800693    ;         li      a3, lcd_ctrl_cmd
